#include <ESP8266WiFi.h>
#include <SoftwareSerial.h>

#define FLOW_SENSOR  D4
#define RELAY        D2
#define PH_RX        D6
#define PH_TX        D5
#define ANALOG_IN    A0
#define DRY_SOIL     900
#define WET_SOIL     300
#define DEEP_SLEEP_MINUTES 15

const char* wifi_ssid     = "//";
const char* wifi_password = "//";
const char* ts_server     = "://thingspeak.com";
String ts_api_key         = "9Y2ZEIHELXD2MR5C";

SoftwareSerial ph_serial(PH_RX, PH_TX);
WiFiClient client;
volatile int flow_pulse_count = 0;

struct {
  float total_moisture;
  float total_ph;
  float total_flow;
  int reading_count;
} rtc_metrics;

void IRAM_ATTR handle_flow_pulse() {
  flow_pulse_count++;
}

void setup() {
  Serial.begin(9600);
  ph_serial.begin(9600);

  pinMode(FLOW_SENSOR, INPUT);
  pinMode(RELAY, OUTPUT);
  digitalWrite(RELAY, HIGH); 

  ESP.rtcUserMemoryRead(0, (uint32_t*)&rtc_metrics, sizeof(rtc_metrics));
  if (rtc_metrics.reading_count < 0 || rtc_metrics.reading_count > 1000) {
    memset(&rtc_metrics, 0, sizeof(rtc_metrics));
  }
  int raw_soil = analogRead(ANALOG_IN);
  int moisture = map(raw_soil, WET_SOIL, DRY_SOIL, 0, 100);
  moisture = constrain(moisture, 0, 100);
  delay(1000);
  float ph_value = 0.0;
  if (ph_serial.available()) {
    String buffer = ph_serial.readStringUntil('\n');
    int target_index = buffer.indexOf("PH:");
    if (target_index != -1) {
      ph_value = buffer.substring(target_index + 3).toFloat();
    }
  }

  bool is_irrigating = false;
  if (moisture < 30 && ph_value >= 6.0 && ph_value <= 9.0) {
    digitalWrite(RELAY, LOW); 
    is_irrigating = true;
    
    attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR), handle_flow_pulse, RISING);
    delay(5000); // 5-second sampling burst for steady-state volume measurement
    detachInterrupt(digitalPinToInterrupt(FLOW_SENSOR));
    
    digitalWrite(RELAY, HIGH); 
  }

  float flow_rate = (is_irrigating) ? (flow_pulse_count / 7.5) : 0.0; // Litres per minute
  float flow_per_hour = flow_rate * 60.0;

  rtc_metrics.total_moisture += moisture;
  rtc_metrics.total_ph       += ph_value;
  rtc_metrics.total_flow     += flow_per_hour;
  rtc_metrics.reading_count++;

  float avg_moisture = rtc_metrics.total_moisture / rtc_metrics.reading_count;
  float avg_ph       = rtc_metrics.total_ph       / rtc_metrics.reading_count;
  float avg_flow     = rtc_metrics.total_flow     / rtc_metrics.reading_count;
  ESP.rtcUserMemoryWrite(0, (uint32_t*)&rtc_metrics, sizeof(rtc_metrics));

  WiFi.begin(wifi_ssid, wifi_password);
  int connection_timeout = 0;

  while (WiFi.status() != WL_CONNECTED && connection_timeout < 25) {
    delay(500);
    connection_timeout++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    if (client.connect(ts_server, 80)) {
      String payload = "/update?api_key=" + ts_api_key;
      payload += "&field1=" + String(moisture)     + "&field2=" + String(ph_value) + "&field3=" + String(flow_per_hour);
      payload += "&field4=" + String(avg_moisture) + "&field5=" + String(avg_ph)   + "&field6=" + String(avg_flow);

      client.print(String("GET ") + payload + " HTTP/1.1\r\n" +
                   "Host: " + ts_server + "\r\n" +
                   "Connection: close\r\n\r\n");
      delay(15); 
      client.stop();
      Serial.println(F("Telemetry updated successfully."));
    }
  } else {
    Serial.println(F("Wi-Fi Connection Fault. Skipping payload."));
  }

  Serial.println(F("Shutting down core peripherals. Entering Deep Sleep."));
  ESP.deepSleep(DEEP_SLEEP_MINUTES * 60 * 1000000);
}

void loop() {
}
